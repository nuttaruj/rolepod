{
  "_comment": "Rolepod Codex hooks. 5 plugin hooks — byte-exact mirrors of root hooks/*.sh (parity enforced by tests/static/lean-surface.sh). Claude-only hooks (block-subagent-commit, cohesion-contract-check, session-lifecycle, gitnexus-wrap) are not registered here because Codex has no Agent / Stop event API and uses a different plugin model.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PLUGIN_ROOT}/hooks/project-context-loader.sh",
            "statusMessage": "Loading project context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PLUGIN_ROOT}/hooks/gate-reminder.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PLUGIN_ROOT}/hooks/precommit-gate.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PLUGIN_ROOT}/hooks/verify-reminder.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${PLUGIN_ROOT}/hooks/post-ship-detect.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
