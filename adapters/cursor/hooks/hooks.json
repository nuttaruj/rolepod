{
  "hooks": {
    "sessionStart": [
      {
        "command": "./scripts/project-context-loader.sh",
        "timeout": 5
      }
    ],
    "preToolUse": [
      {
        "command": "./scripts/gate-reminder.sh",
        "matcher": "Write|Edit|MultiEdit",
        "timeout": 3
      }
    ],
    "beforeShellExecution": [
      {
        "command": "./scripts/precommit-gate.sh",
        "matcher": "git commit",
        "timeout": 5
      }
    ]
  }
}
